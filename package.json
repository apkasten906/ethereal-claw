{
  "name": "ethereal-claw",
  "version": "0.1.0",
  "private": true,
  "description": "CLI-first orchestration layer for AI-assisted software delivery.",
  "license": "MIT",
  "packageManager": "npm@10.9.0",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "branchname:check": "node scripts/check-branch-name.mjs",
    "build": "tsc -b",
    "clean": "rimraf packages/*/dist coverage",
    "cli": "node packages/cli/dist/index.js",
    "commitlint": "commitlint",
    "ec": "node packages/cli/dist/index.js",
    "ethereal": "node packages/cli/dist/index.js",
    "lint": "node ./node_modules/eslint/bin/eslint.js .",
    "link:cli": "npm link --workspace @ethereal-claw/cli",
    "prepare": "husky",
    "pretest": "tsc -b",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -b --pretty false",
    "unlink:cli": "npm unlink -g @ethereal-claw/cli"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.1.0",
    "@commitlint/config-conventional": "^20.0.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^24.6.0",
    "@eslint/js": "^9.37.0",
    "eslint": "^9.37.0",
    "globals": "^16.4.0",
    "husky": "^9.1.7",
    "rimraf": "^6.0.1",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.1",
    "vitest": "^4.1.5"
  }
}
